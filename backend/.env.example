DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webby_seo
PORT=3001
TENANT_ID=00000000-0000-0000-0000-000000000001
CORS_ORIGIN=http://localhost:5173

# DataForSEO credentials (required for rank tracking)
DATAFORSEO_LOGIN=your_login@email.com
DATAFORSEO_PASSWORD=your_api_password

# AI Provider: openai | gemini | template (default: template)
AI_PROVIDER=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Video Rendering Provider: placeholder | synthesia (default: placeholder)
VIDEO_RENDER_PROVIDER=placeholder
SYNTHESIA_API_KEY=

# TTS Provider: placeholder | elevenlabs (default: placeholder)
TTS_PROVIDER=placeholder
ELEVENLABS_API_KEY=

# Social Publishing Credentials (optional — leave empty for placeholder mode)
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
YOUTUBE_API_KEY=
